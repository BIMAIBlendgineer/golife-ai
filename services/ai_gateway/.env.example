LLM_PROVIDER=openrouter
AI_GATEWAY_ENABLE_MOCK=true
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemini-2.0-flash-001
OPENROUTER_FALLBACK_MODEL=
FEEDBACK_STORE_PATH=.runtime/mission_feedback.json
OPERATIONAL_BACKEND_ENABLED=true
OPERATIONAL_BACKEND_BASE_URL=http://127.0.0.1:8010
OPERATIONAL_BACKEND_INGESTION_TOKEN=golife-ingest-dev
OPERATIONAL_BACKEND_TIMEOUT_SECONDS=2.0
OPERATIONAL_BACKEND_MAX_RETRIES=2
ROUTING_CONTROL_ENABLED=true
ROUTING_BACKEND_BASE_URL=http://127.0.0.1:8010
ROUTING_BACKEND_INTERNAL_TOKEN=golife-internal-dev
ROUTING_CONFIG_TIMEOUT_SECONDS=3.0
ROUTING_CONFIG_CACHE_PATH=.runtime/ai_routing_config.json
CRISIS_RESOURCES_REGION=global
CRISIS_RESOURCES_CATALOG_PATH=config/crisis_resources.catalog.json
