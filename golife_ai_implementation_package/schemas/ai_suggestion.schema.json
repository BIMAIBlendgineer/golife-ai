{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AISuggestion",
  "type": "object",
  "required": [
    "suggestion_id",
    "title",
    "recommendation_type",
    "body",
    "evidence",
    "confidence",
    "uncertainty",
    "requires_confirmation",
    "status"
  ],
  "properties": {
    "suggestion_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "domain_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendation_type": {
      "enum": [
        "mission",
        "plan_adjustment",
        "task_rewrite",
        "warning",
        "reflection"
      ]
    },
    "body": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "uncertainty": {
      "type": "string"
    },
    "requires_confirmation": {
      "type": "boolean"
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": [
        "draft",
        "shown",
        "accepted",
        "rejected",
        "edited",
        "expired"
      ]
    }
  }
}
